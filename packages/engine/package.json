{
  "name": "@docsmint/engine",
  "version": "1.0.5",
  "packageManager": "pnpm@10.4.1",
  "type": "module",
  "files": [
    "src",
    "public",
    "plugins",
    "astro.config.mjs",
    "tsconfig.json",
    "docsmint.config.ts"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./plugins": "./src/plugins/contracts.ts"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node -e \"const fs=require('node:fs'); fs.rmSync('.astro',{recursive:true,force:true}); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('node_modules/.astro',{recursive:true,force:true})\" && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "test": "node --test test/*.test.mjs"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.5",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.4",
    "@astrojs/sitemap": "3.7.2",
    "@docsmint/config": "workspace:*",
    "@tailwindcss/vite": "4.2.4",
    "astro": "6.1.9",
    "jiti": "2.6.1",
    "mermaid": "11.14.0",
    "pagefind": "1.5.2",
    "rehype-external-links": "3.0.0",
    "rehype-pretty-code": "0.14.3",
    "shiki": "4.0.2",
    "tailwindcss": "4.2.4",
    "unist-util-visit": "5.1.0",
    "vite": "7.3.2"
  },
  "private": true
}
