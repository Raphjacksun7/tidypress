---
export interface Props {
  type?: 'note' | 'warning' | 'tip'
}
const { type = 'note' } = Astro.props
const label = { note: 'Note', warning: 'Warning', tip: 'Tip' }[type]
---
<div class="not-prose my-6 pl-4 text-sm"
     style="border-left: 2px solid var(--fg)">
  <p style="font-size:0.6875rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.25rem; color:var(--muted)">
    {label}
  </p>
  <div style="line-height:1.7; color:var(--fg)">
    <slot />
  </div>
</div>
