---
export interface Props {
  labels: string[]
}
const { labels } = Astro.props
const id = Math.random().toString(36).slice(2, 8)
---
<div class="tabs not-prose my-6" data-tabs={id}>
  <div class="flex gap-0 border-b" style="border-color:var(--border)">
    {labels.map((label, i) => (
      <button
        class="tab-btn text-xs px-3 py-1.5 font-mono cursor-pointer border-b-2 -mb-px transition-colors"
        style={`border-color:${i === 0 ? 'var(--fg)' : 'transparent'}; color:${i === 0 ? 'var(--fg)' : 'var(--muted)'}; background:none; border-top:none; border-left:none; border-right:none`}
        data-tab={i}
        data-tabs-id={id}
      >{label}</button>
    ))}
  </div>
  <div class="tab-panels">
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll('[data-tabs]').forEach(container => {
    const id = container.getAttribute('data-tabs')
    const btns = container.querySelectorAll('.tab-btn')
    const panels = container.querySelectorAll('.tab-panel')

    btns.forEach((btn, i) => {
      btn.addEventListener('click', () => {
        btns.forEach((b, j) => {
          const active = j === i
          ;(b as HTMLElement).style.borderColor = active ? 'var(--fg)' : 'transparent'
          ;(b as HTMLElement).style.color = active ? 'var(--fg)' : 'var(--muted)'
        })
        panels.forEach((p, j) => {
          (p as HTMLElement).style.display = j === i ? 'block' : 'none'
        })
      })
    })

    // Init: hide all but first
    panels.forEach((p, i) => {
      (p as HTMLElement).style.display = i === 0 ? 'block' : 'none'
    })
  })
</script>
