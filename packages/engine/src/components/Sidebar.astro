---
import { getCollection } from 'astro:content'
import { getConfig } from '../config/getConfig'
import { sortDocs } from '../domain/content/sortDocs'
import { onlyPublished } from '../domain/content/published'
import { localizeEntries, resolveLocale, withLocalePrefix } from '../i18n/locale'
import {
  getEnabledContentCollections,
  getLocalizedCollectionBasePath,
  isLegacyStarterCollectionKey,
} from '../domain/content/collections'
import {
  resolveActiveVersionPath,
  stripDocExtension,
  versionContentPrefix,
} from '../routing/versioning'

const rawSite = (await import('../../docsmint.config.ts')).default
const site = getConfig(rawSite)
const localeState = resolveLocale(Astro.url.pathname, site.i18n)
const activeLocale = localeState.activeLocale
const docsCollections = getEnabledContentCollections(site)
  .filter(collection => collection.kind === 'docs')
  .map(collection => ({
    id: collection.key,
    basePath: getLocalizedCollectionBasePath(site, collection.key, activeLocale),
    isLegacy: isLegacyStarterCollectionKey(site, collection.key),
  }))
const fallbackCollection = docsCollections.find(collection => collection.id === 'docs') ?? docsCollections[0]
const activeDocsCollection = docsCollections.find(({ basePath }) =>
  Astro.url.pathname === basePath || Astro.url.pathname.startsWith(`${basePath}/`),
) ?? fallbackCollection
if (!activeDocsCollection) {
  throw new Error('No enabled docs-like collections available for Sidebar.')
}
const docsBasePath = activeDocsCollection.basePath
const targetLocale = localeState.activeLocale ?? localeState.defaultLocale
const docs = sortDocs(localizeEntries(
  onlyPublished(await getCollection(activeDocsCollection.id as any)),
  localeState,
  targetLocale,
).map(item => ({
  ...item.entry,
  id: item.slug,
})))
const localizedVersions = (site.versions ?? []).map(version => ({
  ...version,
  path: withLocalePrefix(version.path, localeState.activeLocale),
}))
const activeVersionPath = activeDocsCollection.isLegacy
  ? resolveActiveVersionPath(localizedVersions, Astro.url.pathname)
  : undefined
const activeContentPrefix = activeVersionPath ? versionContentPrefix(activeVersionPath, docsBasePath) : undefined
const visibleDocs = activeContentPrefix
  ? docs.filter(entry => {
      const id = stripDocExtension(entry.id)
      return id === activeContentPrefix || id.startsWith(`${activeContentPrefix}/`)
    })
  : docs
const firstDocHref = visibleDocs[0]
  ? `${docsBasePath}/${stripDocExtension(visibleDocs[0].id)}`
  : undefined

const tree: Record<string, { title: string; href: string }[]> = {}

for (const entry of visibleDocs) {
  const entryId = stripDocExtension(entry.id)
  const displayId =
    activeContentPrefix && entryId.startsWith(`${activeContentPrefix}/`)
      ? entryId.slice(activeContentPrefix.length + 1)
      : entryId
  const parts = displayId.split('/')
  const section = parts.length > 1 ? parts[0] : ''
  tree[section] = tree[section] || []
  tree[section].push({
    title: entry.data.title,
    href: `${docsBasePath}/${entryId}`,
  })
}

const sections = Object.entries(tree).sort(([a], [b]) => a.localeCompare(b))
const currentPath = Astro.url.pathname
---
<nav class="space-y-6">
  {sections.map(([section, pages]) => (
    <div>
      {section && (
        <p class="font-bold text-xs uppercase tracking-wide mb-2">{section}</p>
      )}
      <ul class="space-y-1">
        {pages.map(({ title, href }) => {
          const active =
            currentPath === href ||
            ((currentPath === docsBasePath || currentPath === `${docsBasePath}/`) &&
              href === firstDocHref)
          return (
            <li>
              <a
                href={href}
                class:list={[
                  'block py-0.5',
                  active ? 'font-bold' : 'text-zinc-500',
                ]}
                style={active ? 'text-decoration:none' : ''}
                data-sidebar-active={active ? '' : undefined}
                data-sidebar-link=""
              >{title}</a>
            </li>
          )
        })}
      </ul>
    </div>
  ))}
</nav>
