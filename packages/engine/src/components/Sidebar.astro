---
import { getConfig } from '@/config/getConfig'
import { sortDocs } from '@/utils/sort'
import { loadPublishedCollectionEntries } from '@/utils/collection-entries'
import { localizeEntries, resolveLocale, withLocalePrefix } from '@/i18n/locale'
import { collectionKindUsesDocsSidebar, isDocsMintCollectionKind, isDocsStarterKey } from '@docsmint/config'
import {
  getEnabledContentCollections,
  getLocalizedCollectionBasePath,
} from '@/utils/collections'
import {
  normalizePathname,
  resolveActiveVersionPath,
  stripDocExtension,
  versionContentPrefix,
} from '@/routing/versioning'

const rawSite = (await import('@site-config')).default
const site = getConfig(rawSite)
const localeState = resolveLocale(Astro.url.pathname, site.i18n)
const activeLocale = localeState.activeLocale
const docsCollections = getEnabledContentCollections(site)
  .filter(
    collection =>
      isDocsStarterKey(collection.key) ||
      (isDocsMintCollectionKind(collection.kind) && collectionKindUsesDocsSidebar(collection.kind)),
  )
  .map(collection => ({
    id: collection.key,
    basePath: getLocalizedCollectionBasePath(site, collection.key, activeLocale),
    versionAware: isDocsStarterKey(collection.key) && (site.versions?.length ?? 0) > 0,
  }))
const fallbackCollection = docsCollections.find(collection => collection.id === 'docs') ?? docsCollections[0]
const activeDocsCollection = docsCollections.find(({ basePath }) =>
  Astro.url.pathname === basePath || Astro.url.pathname.startsWith(`${basePath}/`),
) ?? fallbackCollection
if (!activeDocsCollection) {
  throw new Error('No enabled docs-like collections available for Sidebar.')
}
const docsBasePath = activeDocsCollection.basePath
const targetLocale = localeState.activeLocale ?? localeState.defaultLocale
const docs = sortDocs(localizeEntries(
  await loadPublishedCollectionEntries(activeDocsCollection.id),
  localeState,
  targetLocale,
).map(item => ({
  ...item.entry,
  id: item.slug,
})))
const localizedVersions = (site.versions ?? []).map(version => ({
  ...version,
  path: withLocalePrefix(version.path, localeState.activeLocale),
}))
const activeVersionPath = activeDocsCollection.versionAware
  ? resolveActiveVersionPath(localizedVersions, Astro.url.pathname)
  : undefined
const activeContentPrefix = activeVersionPath ? versionContentPrefix(activeVersionPath, docsBasePath) : undefined
const visibleDocs = activeContentPrefix
  ? docs.filter(entry => {
      const id = stripDocExtension(entry.id)
      return id === activeContentPrefix || id.startsWith(`${activeContentPrefix}/`)
    })
  : docs
const firstDocHref = visibleDocs[0]
  ? `${docsBasePath}/${stripDocExtension(visibleDocs[0].id)}`
  : undefined

type SidebarPage = { title: string; href: string }
type SidebarSection = { label?: string; pages: SidebarPage[] }

// Build a slug→entry map for fast lookup (strips version prefix for display)
const entryByDisplaySlug = new Map<string, { title: string; href: string }>()
for (const entry of visibleDocs) {
  const entryId = stripDocExtension(entry.id)
  const displayId =
    activeContentPrefix && entryId.startsWith(`${activeContentPrefix}/`)
      ? entryId.slice(activeContentPrefix.length + 1)
      : entryId
  entryByDisplaySlug.set(displayId, {
    title: (entry.data as { title?: string }).title ?? entry.id,
    href: `${docsBasePath}/${entryId}`,
  })
}

let sections: SidebarSection[]

const configuredSidebar = site.docs?.sidebar
if (configuredSidebar && configuredSidebar.length > 0) {
  // Explicit section groups from config
  sections = configuredSidebar.map(group => ({
    label: group.label,
    pages: group.items.flatMap(slug => {
      const page = entryByDisplaySlug.get(slug)
      return page ? [page] : []
    }),
  })).filter(s => s.pages.length > 0)
} else {
  // Auto-group by folder path (existing behavior)
  const tree: Record<string, SidebarPage[]> = {}
  for (const [displayId, page] of entryByDisplaySlug) {
    const parts = displayId.split('/')
    const section = parts.length > 1 ? parts[0] : ''
    tree[section] = tree[section] || []
    tree[section].push(page)
  }
  sections = Object.entries(tree)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([label, pages]) => ({ label: label || undefined, pages }))
}
const currentPath = normalizePathname(Astro.url.pathname)
---
<nav class="space-y-6">
  {sections.map(({ label, pages }) => (
    <div>
      {label && (
        <p class="font-bold text-xs uppercase tracking-wide mb-2" style="color:var(--muted)">{label}</p>
      )}
      <ul class="space-y-1">
        {pages.map(({ title, href }) => {
          const normalizedHref = normalizePathname(href)
          const normalizedBase = normalizePathname(docsBasePath)
          const active =
            currentPath === normalizedHref ||
            (firstDocHref !== undefined &&
              currentPath === normalizedBase &&
              normalizedHref === normalizePathname(firstDocHref))
          return (
            <li>
              <a
                href={href}
                class="block py-0.5"
                data-sidebar-active={active ? '' : undefined}
                data-sidebar-link=""
              >{title}</a>
            </li>
          )
        })}
      </ul>
    </div>
  ))}
</nav>
