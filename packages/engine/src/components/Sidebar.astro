---
import { getCollection } from 'astro:content'
import { getConfig } from '../config/getConfig'
import { sortDocs } from '../utils/sortDocs'

const rawSite = (await import('../../docsmint.config.ts')).default
const site = getConfig(rawSite)
const docsBasePath = site.sections?.docs?.basePath ?? '/docs'
const docs = sortDocs(await getCollection('docs'))

const tree: Record<string, { title: string; href: string }[]> = {}

for (const entry of docs) {
  const parts = entry.id.replace(/\.mdx?$/, '').split('/')
  const section = parts.length > 1 ? parts[0] : ''
  tree[section] = tree[section] || []
  tree[section].push({
    title: entry.data.title,
    href: `${docsBasePath}/${entry.id.replace(/\.mdx?$/, '')}`,
  })
}

const sections = Object.entries(tree).sort(([a], [b]) => a.localeCompare(b))
const currentPath = Astro.url.pathname
---
<nav class="text-sm space-y-6">
  {sections.map(([section, pages]) => (
    <div>
      {section && (
        <p class="font-bold text-xs uppercase tracking-wide mb-2">{section}</p>
      )}
      <ul class="space-y-1">
        {pages.map(({ title, href }) => (
          <li>
            <a
              href={href}
              class:list={['block py-0.5', currentPath === href ? 'font-bold' : 'text-zinc-500']}
              style={currentPath === href ? 'text-decoration:none' : ''}
            >{title}</a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>
