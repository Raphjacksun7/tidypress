---
// FileTree — collapsible file/directory tree from slot markdown.
// Directories fold on click. Use **filename** to highlight a file.
// Usage:
//   <FileTree>
//   - src/
//     - index.astro
//     - **config.ts**
//   </FileTree>
---
<div class="file-tree not-prose my-6 font-mono overflow-x-auto"
     style="border:1px solid var(--border);border-radius:4px;padding:0.875rem 1rem">
  <slot />
</div>

<script>
  document.querySelectorAll('.file-tree').forEach(tree => {
    tree.querySelectorAll('li').forEach(li => {
      const childUl = li.querySelector(':scope > ul')
      if (!childUl) return

      const labelNodes = Array.from(li.childNodes).filter(n => {
        if (n === childUl) return false
        if (n.nodeType === Node.TEXT_NODE && (n as Text).data.trim() === '') return false
        return true
      })

      const details = document.createElement('details')
      details.setAttribute('open', '')
      const summary = document.createElement('summary')
      labelNodes.forEach(n => summary.appendChild(n))
      details.appendChild(summary)
      details.appendChild(childUl)
      li.appendChild(details)
    })
  })
</script>

<style>
.file-tree :global(ul) {
  list-style: none;
  margin: 0;
  padding: 0;
}

.file-tree :global(> ul) {
  padding: 0;
}

.file-tree :global(ul ul) {
  padding-left: 1.25rem;
  border-left: 1px solid var(--border);
  margin-left: 0.4rem;
}

.file-tree :global(li) {
  padding: 0.1rem 0;
  display: flex;
  align-items: flex-start;
  gap: 0.375rem;
  color: var(--fg);
  font-size: 0.8125rem;
  line-height: 1.6;
}

/* Directory li wraps a details element */
.file-tree :global(li:has(> details)),
.file-tree :global(li:has(> ul)) {
  display: block;
}

/* File entries — spacer to align with directory ▸ */
.file-tree :global(li:not(:has(> ul)):not(:has(> details)))::before {
  content: '';
  width: 0.5rem;
  flex-shrink: 0;
  display: inline-block;
}

/* ── details inside file-tree — override global styles ── */
.file-tree :global(details) {
  margin: 0;
  padding: 0;
  border: none;
}

.file-tree :global(details[open]) {
  padding: 0;
  border: none;
}

.file-tree :global(details summary) {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  cursor: pointer;
  list-style: none;
  padding: 0.1rem 0;
  user-select: none;
  font-size: 0.8125rem;
  font-weight: inherit;
  color: var(--fg);
}

.file-tree :global(details summary::before) {
  content: '▸';
  font-size: 0.55rem;
  color: var(--muted);
  flex-shrink: 0;
  width: 0.5rem;
}

.file-tree :global(details[open] > summary::before) {
  content: '▾';
}

/* Pre-JS: directory indicator on li directly containing ul */
.file-tree :global(li:has(> ul))::before {
  content: '▸';
  font-size: 0.55rem;
  color: var(--muted);
  flex-shrink: 0;
}

/* Highlighted file */
.file-tree :global(strong) {
  font-weight: 700;
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* Clickable links */
.file-tree :global(a) {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 3px;
}

.file-tree :global(a:hover) {
  background: var(--fg);
  color: var(--bg);
  padding-inline: 2px;
  margin-inline: -2px;
}
</style>
