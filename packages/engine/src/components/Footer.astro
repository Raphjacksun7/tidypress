---
<footer class="max-w-3xl mx-auto px-8 py-6 mt-4">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-t border-zinc-100 pt-6">
    <div class="flex items-center gap-3">
      <p class="text-xs text-zinc-400">&copy; {new Date().getFullYear()} {site.name}</p>
      <LanguageSelector
        locales={locales}
        activeLocale={activeLocale}
        defaultLocale={defaultLocale}
        label={languageLabel}
        site={site}
      />
    </div>

    {hasRight && (
      <div class="flex items-center gap-3">
        {iconItems.map(item => (
          <a
            href={item.href}
            class="footer-icon-link"
            target={item.external !== false ? '_blank' : undefined}
            rel={item.external !== false ? 'noopener noreferrer' : undefined}
            aria-label={item.label}
          >
            <span class="sr-only">{item.label}</span>
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              width="18"
              height="18"
              aria-hidden="true"
            >
              <path d={icons[item.icon as FooterItemIcon]} />
            </svg>
          </a>
        ))}
        {textItems.map(item => (
          <a
            href={item.href}
            class="text-xs text-zinc-400 footer-text-link"
            target={item.external !== false && item.href.startsWith('http') ? '_blank' : undefined}
            rel={item.external !== false && item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>
    )}
  </div>
</footer>
