---
import type { DocsMintConfig, FooterItemIcon } from '@docsmint/config'
import LanguageSelector from '@/components/LanguageSelector.astro'

export interface Props {
  site: DocsMintConfig
  locales: string[]
  activeLocale?: string
  defaultLocale: string
  languageLabel: string
}

const { site, locales, activeLocale, defaultLocale, languageLabel } = Astro.props

