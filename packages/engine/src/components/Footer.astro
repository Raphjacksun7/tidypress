---
import { formatFooterCopyright, type TidyPressConfig, type TidyPressFooter } from '@tidypress/config'
import FooterMainSlot from '@/components/FooterMainSlot.astro'
import LanguageSelector from '@/components/LanguageSelector.astro'
import FooterIcon from '@/components/FooterIcon.astro'

export interface Props {
  site: TidyPressConfig
  locales: string[]
  activeLocale?: string
  defaultLocale: string
  languageLabel: string
}

const { site, locales, activeLocale, defaultLocale, languageLabel } = Astro.props

const footer = site.footer as TidyPressFooter
const { main, links, copyright: copyrightTemplate, showCredit, credit } = footer
const mainStart = main.start
const mainEnd = main.end
const copyrightLine = formatFooterCopyright(copyrightTemplate, {
  year: new Date().getFullYear(),
  name: site.name,
})
const hasLinks = links.length > 0
const showLangSelector = locales.length > 1
const showMain = Boolean(mainStart || mainEnd || showLangSelector)
---
<footer class="max-w-3xl mx-auto px-8 py-6 mt-4">
  {showMain && (
    <div
      class="tidy-footer tidy-footer-main pt-6"
      data-footer-zone="main"
    >
      {mainStart && (
        <div class="tidy-footer-main__start" data-footer-slot="start">
          <FooterMainSlot slot={mainStart} />
        </div>
      )}
      {(mainEnd || showLangSelector) && (
        <div class="tidy-footer-main__end" data-footer-slot="end">
          {mainEnd && <FooterMainSlot slot={mainEnd} />}
          {showLangSelector && (
            <LanguageSelector
              locales={locales}
              activeLocale={activeLocale}
              defaultLocale={defaultLocale}
              label={languageLabel}
              site={site}
            />
          )}
        </div>
      )}
    </div>
  )}

  <div
    class:list={[
      'tidy-footer-sub',
      !showMain && 'tidy-footer-sub--lead',
      !hasLinks && 'tidy-footer-sub-attribution-only',
      hasLinks && !showCredit && 'tidy-footer-sub-links-only',
    ]}
    data-footer-zone="sub"
  >
    {hasLinks && (
      <div class="tidy-footer-sub-links" data-footer-slot="links">
        {links.map(item =>
          item.icon ? (
            <a
              href={item.href}
              class="footer-icon-link"
              target={item.target}
              rel={item.rel}
              aria-label={item.label}
            >
              <span class="sr-only">{item.label}</span>
              <FooterIcon icon={item.icon} />
            </a>
          ) : (
            <a
              href={item.href}
              class="tidy-footer-copyright footer-text-link"
              target={item.target}
              rel={item.rel}
            >
              {item.label}
            </a>
          ),
        )}
      </div>
    )}

    <p class="tidy-footer-credit" data-footer-slot="attribution">
      {copyrightLine}{credit && (
        <>
          {credit.prefix}
          <a href={credit.href}>{credit.label}</a>
        </>
      )}
    </p>
  </div>
</footer>
