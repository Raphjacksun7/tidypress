---
/**
 * Individual step inside a <Steps> block.
 * Renders as a numbered list item. An optional `title` appears bold above the body.
 *
 * Usage in MDX:
 *   <Steps>
 *     <Step title="Install">Run `npm install`</Step>
 *     <Step title="Configure">Edit `tidypress.config.ts`</Step>
 *   </Steps>
 */
interface Props {
  title?: string
}
const { title } = Astro.props
---
<li class="tidy-step">
  {title && <span class="tidy-step__title">{title}</span>}
  <slot />
</li>
