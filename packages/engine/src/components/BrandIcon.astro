---
import { existsSync } from 'node:fs'
import { readFile } from 'node:fs/promises'
import { join } from 'node:path'

export interface Props {
  src: string
  sizeClass?: string
}

const { src, sizeClass = 'size-[1.05em]' } = Astro.props
const isSvg = /\.svg(?:$|[?#])/i.test(src)
const assetPath = src.split('?')[0]?.split('#')[0] ?? src
const safeUrl = src.replace(/'/g, "\\'")

const MAX_INLINE_SVG_BYTES = 12000

let inlineSvg = ''
if (isSvg && assetPath.startsWith('/')) {
  const candidates = [
    join(process.cwd(), 'public', assetPath.slice(1)),
    join(process.cwd(), assetPath.slice(1)),
  ]
  for (const candidate of candidates) {
    if (!existsSync(candidate)) {
      continue
    }
    const raw = await readFile(candidate, 'utf8')
    // Large traced SVGs are better as external URLs (lighter HTML, safer layout behavior).
    if (Buffer.byteLength(raw, 'utf8') > MAX_INLINE_SVG_BYTES) {
      inlineSvg = ''
      break
    }
    inlineSvg = raw
      .replace(/<\?xml[\s\S]*?\?>/gi, '')
      .replace(/<!DOCTYPE[\s\S]*?>/gi, '')
      .replace(/<style[\s\S]*?<\/style>/gi, '')
      .replace(
        /<svg([^>]*)>/i,
        '<svg$1 focusable="false" aria-hidden="true" preserveAspectRatio="xMidYMid meet">',
      )
    break
  }
}
---
{isSvg && inlineSvg ? (
  <span
    aria-hidden="true"
    class:list={['brand-icon-svg', 'inline-block shrink-0 align-middle', sizeClass]}
    set:html={inlineSvg}
  ></span>
) : isSvg ? (
  <span
    aria-hidden="true"
    class:list={['brand-icon-url', 'inline-block shrink-0 align-middle', sizeClass]}
    style={`--brand-icon-url: url('${safeUrl}')`}
  ></span>
) : (
  <img
    aria-hidden="true"
    alt=""
    src={src}
    class:list={['brand-icon-raster', 'inline-block shrink-0 align-middle object-contain', sizeClass]}
    loading="eager"
    decoding="async"
  />
)}

<style>
.brand-icon-svg :global(svg) {
  width: 100%;
  height: 100%;
  display: block;
}

.brand-icon-svg :global(svg *),
.brand-icon-svg :global(svg path),
.brand-icon-svg :global(svg polygon),
.brand-icon-svg :global(svg circle),
.brand-icon-svg :global(svg ellipse) {
  fill: currentColor !important;
}

.brand-icon-svg :global(svg line),
.brand-icon-svg :global(svg polyline),
.brand-icon-svg :global(svg path[stroke]),
.brand-icon-svg :global(svg [stroke]) {
  stroke: currentColor !important;
}

.brand-icon-url {
  background-color: currentColor;
  -webkit-mask-image: var(--brand-icon-url);
  mask-image: var(--brand-icon-url);
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
  -webkit-mask-size: contain;
  mask-size: contain;
}

.brand-icon-raster {
  filter: grayscale(1) contrast(1.15) brightness(0);
}

[data-theme="dark"] .brand-icon-raster {
  filter: grayscale(1) contrast(1.1) brightness(0) invert(1);
}

@media (prefers-color-scheme: dark) {
  :root:not([data-theme="light"]) .brand-icon-raster {
    filter: grayscale(1) contrast(1.1) brightness(0) invert(1);
  }
}
</style>
