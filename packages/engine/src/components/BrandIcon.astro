---
import { loadProjectIcon } from '@/utils/brand-icon'

export interface Props {
  src: string
  sizeClass?: string
  /** `entry` = project card tile on home (black box, white glyph). */
  variant?: 'default' | 'entry'
}

const { src, sizeClass = 'size-[1.05em]', variant = 'default' } = Astro.props
const icon = await loadProjectIcon(src)
const safeMaskUrl = src.replace(/'/g, "\\'")
const classes = ['brand-icon', sizeClass, variant === 'entry' && 'brand-icon--entry'].filter(Boolean)
---

{icon.mode === 'inline' ? (
  <span
    aria-hidden="true"
    class:list={[...classes, 'brand-icon--inline']}
    set:html={icon.markup}
  />
) : icon.mode === 'mask' ? (
  <span
    aria-hidden="true"
    class:list={[...classes, 'brand-icon--mask']}
    style={`--brand-icon-url: url('${safeMaskUrl}')`}
  />
) : (
  <img
    aria-hidden="true"
    alt=""
    src={icon.url}
    class:list={[...classes, 'brand-icon--raster']}
    loading="eager"
    decoding="async"
  />
)}
