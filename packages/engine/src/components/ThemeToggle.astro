---
export interface Props {
  enabled?: boolean
}
const { enabled = true } = Astro.props
---
{enabled && (
<button
  type="button"
  id="theme-toggle"
  aria-label="Toggle light/dark mode"
  class="text-sm text-zinc-500 cursor-pointer"
  style="background:none; border:none; font-family:inherit; padding:0"
>
  <span id="theme-label">light</span>
</button>
)}

<script is:inline>
  (function () {
    var root = document.documentElement
    var toggleButton = document.getElementById('theme-toggle')
    var themeLabel = document.getElementById('theme-label')
    if (!toggleButton || !themeLabel) {
      return
    }

    function readTheme() {
      var stored = root.getAttribute('data-theme')
      if (stored === 'dark' || stored === 'light') {
        return stored
      }
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
    }

    function applyTheme(theme) {
      root.setAttribute('data-theme', theme)
      themeLabel.textContent = theme
      localStorage.setItem('theme', theme)
    }

    applyTheme(readTheme())

    toggleButton.addEventListener('click', function () {
      applyTheme(readTheme() === 'dark' ? 'light' : 'dark')
    })

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
      if (!localStorage.getItem('theme')) {
        applyTheme(e.matches ? 'dark' : 'light')
      }
    })
  })()
</script>
