---
// Theme toggle — system auto-detected on first load, manual light/dark toggle.
// No flash: inline script in Base.astro head runs before render.
---
<button
  id="theme-toggle"
  aria-label="Toggle light/dark mode"
  class="text-sm text-zinc-500 cursor-pointer"
  style="background:none; border:none; font-family:inherit; padding:0"
>
  <span id="theme-label">light</span>
</button>

<script>
  const root = document.documentElement
  const btn  = document.getElementById('theme-toggle')!
  const lbl  = document.getElementById('theme-label')!

  function current(): 'light' | 'dark' {
    return root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light'
  }

  function apply(theme: 'light' | 'dark') {
    root.setAttribute('data-theme', theme)
    lbl.textContent = theme
    localStorage.setItem('theme', theme)
  }

  // Set label to match current state (set by the no-flash inline script)
  lbl.textContent = current()

  btn.addEventListener('click', () => {
    apply(current() === 'dark' ? 'light' : 'dark')
  })

  // Keep label in sync if system preference changes and no manual override
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
    if (!localStorage.getItem('theme')) {
      apply(e.matches ? 'dark' : 'light')
    }
  })
</script>
