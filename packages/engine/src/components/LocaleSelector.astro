---
import type { TidyPressConfig } from '@tidypress/config'
import { switchLocaleTarget } from '@/routing/route-equivalents'

const { activeLocale, defaultLocale, label, site } = Astro.props as {
  activeLocale?: string
  defaultLocale: string
  label: string
  site: TidyPressConfig
}
const locales: string[] = Array.isArray(Astro.props.locales) ? Astro.props.locales : []
const pathname = Astro.url.pathname
---
{
  locales.length > 1 && (
    <label class="hidden sm:inline-flex items-center relative">
      <span class="sr-only">{label}</span>
      <select
        aria-label={label}
        class="dm-nav-select"
        onchange="if (this.value) window.location.assign(this.value)"
      >
        {locales.map((locale) => (
          <option
            value={switchLocaleTarget(pathname, locale, site)}
            selected={(activeLocale ?? defaultLocale) === locale}
          >
            {locale}
          </option>
        ))}
      </select>
      <span class="dm-nav-select__chevron" aria-hidden="true">▾</span>
    </label>
  )
}
