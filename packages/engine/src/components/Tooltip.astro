---
export interface Props {
  tip: string
}
const { tip } = Astro.props
---
<span class="relative inline-block group" style="display:inline-block">
  <span style="text-decoration:underline; text-decoration-style:dotted; text-underline-offset:2px; cursor:help">
    <slot />
  </span>
  <span class="
    absolute bottom-full left-1/2 -translate-x-1/2 mb-2
    w-64 px-3 py-2 text-xs leading-relaxed
    opacity-0 invisible
    group-hover:opacity-100 group-hover:visible
    group-focus-within:opacity-100 group-focus-within:visible
    transition-opacity z-10 pointer-events-none
  "
  style="background:var(--fg); color:var(--bg); border-radius:2px">
    {tip}
  </span>
</span>
