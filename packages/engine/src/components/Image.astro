---
// Drop-in MDX replacement for <img>.
// Handles both local (src/assets/) optimized images and remote/public URLs.
// Usage in MDX:
//   ![alt text](./diagram.png)          ← local, gets optimized
//   ![alt text](/public-image.png)      ← served from public/, no processing
import { Image as AstroImage } from 'astro:assets'
import {
  TIDYPRESS_IMAGE_PRESENTATION,
  isRemoteOrPublicImageSrc,
} from '@/utils/image'

export interface Props {
  src: string | ImageMetadata
  alt: string
  width?: number
  height?: number
  caption?: string
}

const { src, alt, width, height, caption } = Astro.props
const isRemoteOrPublic = isRemoteOrPublicImageSrc(src)
---
<figure class={TIDYPRESS_IMAGE_PRESENTATION.figureClass}>
  {isRemoteOrPublic
    ? <img src={src as string} alt={alt} width={width} height={height}
           class={TIDYPRESS_IMAGE_PRESENTATION.frameClass} loading="lazy" />
    : <AstroImage src={src as ImageMetadata} alt={alt}
           width={width ?? TIDYPRESS_IMAGE_PRESENTATION.optimizedWidth}
           height={height ?? TIDYPRESS_IMAGE_PRESENTATION.optimizedHeight}
           class={TIDYPRESS_IMAGE_PRESENTATION.frameClass} />
  }
  {caption && (
    <figcaption class={TIDYPRESS_IMAGE_PRESENTATION.captionClass}>{caption}</figcaption>
  )}
</figure>
