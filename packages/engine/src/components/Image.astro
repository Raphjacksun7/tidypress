---
// Drop-in MDX replacement for <img>.
// Handles both local (src/assets/) optimized images and remote/public URLs.
// Usage in MDX:
//   ![alt text](./diagram.png)          ← local, gets optimized
//   ![alt text](/public-image.png)      ← served from public/, no processing
import { Image as AstroImage } from 'astro:assets'

export interface Props {
  src: string | ImageMetadata
  alt: string
  width?: number
  height?: number
  caption?: string
}

const { src, alt, width, height, caption } = Astro.props
const isRemoteOrPublic = typeof src === 'string' && (src.startsWith('http') || src.startsWith('/'))
---
<figure class="my-8">
  {isRemoteOrPublic
    ? <img src={src as string} alt={alt} width={width} height={height}
           class="max-w-full rounded border border-zinc-200" loading="lazy" />
    : <AstroImage src={src as ImageMetadata} alt={alt}
           width={width ?? 800} height={height ?? 450}
           class="max-w-full rounded border border-zinc-200" />
  }
  {caption && (
    <figcaption class="text-xs text-zinc-400 mt-2 text-center">{caption}</figcaption>
  )}
</figure>
