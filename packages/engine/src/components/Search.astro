---
// Pagefind search — custom UI matching the transfa monospace aesthetic.
// Triggered by pressing / or clicking the search link in the nav.
import { getConfig } from '@/config/getConfig'
import type { TidyPressI18nStrings } from '@tidypress/config'
import { PAGEFIND_COLLECTION_FILTER_KEY } from '@tidypress/config'
import { resolveLocale, withLocalePrefix } from '@/i18n/locale'

export interface Props {
  strings: Required<TidyPressI18nStrings>
  collections?: Array<{ key: string; label: string }>
}

const { strings: searchStrings, collections = [] } = Astro.props
const rawSite = (await import('@site-config')).default
const site = getConfig(rawSite)
const localeState = resolveLocale(Astro.url.pathname, site.i18n)
const localizedVersionPaths = (site.versions ?? []).map(version =>
  withLocalePrefix(version.path, localeState.activeLocale),
)
const showCollectionFilters = collections.length > 1
---

<!-- Search trigger -->
<button
  type="button"
  id="search-trigger"
  class="search-trigger"
  aria-label={searchStrings.searchLabel}
>
  {searchStrings.searchLabel}
  <kbd class="search-kbd">/</kbd>
</button>

<!-- Search modal -->
<div
  id="search-modal"
  class="search-modal hidden"
  role="dialog"
  aria-modal="true"
  aria-label={searchStrings.searchLabel}
>
  <div id="search-backdrop" class="search-backdrop"></div>

  <div class="search-dialog">
    <div class="search-panel">
      <div class="search-input-row">
        <span class="search-input-prefix" aria-hidden="true">→</span>
        <input
          id="search-input"
          type="text"
          placeholder={searchStrings.searchPlaceholder}
          autocomplete="off"
          spellcheck="false"
          class="search-input"
        />
        <kbd id="search-close-hint" class="search-kbd">esc</kbd>
      </div>

      {showCollectionFilters && (
        <div id="search-filters" class="search-filters" role="group" aria-label={searchStrings.searchFilterLabel}>
          <button type="button" class="search-filter search-filter--active" data-search-filter="">
            {searchStrings.searchFilterAllLabel}
          </button>
          {collections.map(collection => (
            <button
              type="button"
              class="search-filter"
              data-search-filter={collection.key}
            >
              {collection.label}
            </button>
          ))}
        </div>
      )}

      <div id="search-results" class="search-results">
        <p id="search-empty" class="search-empty">
          {searchStrings.searchEmptyLabel}
        </p>
      </div>
    </div>
  </div>
</div>

<script
  is:inline
  define:vars={{
    localizedVersionPaths,
    searchStrings,
    pagefindCollectionFilterKey: PAGEFIND_COLLECTION_FILTER_KEY,
    showCollectionFilters,
  }}
>
let pagefind = null
const versionPaths = [...localizedVersionPaths]
let activeCollectionFilter = ''

function normalizePath(value) {
  if (value.length > 1 && value.endsWith('/')) {
    return value.slice(0, -1)
  }
  return value
}

function getActiveVersionPath(pathname) {
  const currentPath = normalizePath(pathname)
  for (const candidate of versionPaths) {
    const normalizedCandidate = normalizePath(candidate)
    if (currentPath === normalizedCandidate || currentPath.startsWith(`${normalizedCandidate}/`)) {
      return normalizedCandidate
    }
  }
  return undefined
}

function inActiveVersion(url, activeVersionPath) {
  try {
    const pathname = normalizePath(new URL(url, window.location.origin).pathname)
    return pathname === activeVersionPath || pathname.startsWith(`${activeVersionPath}/`)
  } catch {
    return false
  }
}

function isExcludedSearchResult(item) {
  const pathname = normalizePath(new URL(item.url, window.location.origin).pathname)
  return pathname === '/404' || pathname.endsWith('/404')
}

function pagefindSearchOptions() {
  if (!showCollectionFilters || !activeCollectionFilter) {
    return {}
  }
  return {
    filters: {
      [pagefindCollectionFilterKey]: activeCollectionFilter,
    },
  }
}

async function loadPagefind() {
  if (pagefind) return pagefind
  try {
    const path = ['', 'pagefind', 'pagefind.js'].join('/')
    pagefind = await import(/* @vite-ignore */ path)
    await pagefind.init()
  } catch {
    pagefind = null
  }
  return pagefind
}

const modal = document.getElementById('search-modal')
const backdrop = document.getElementById('search-backdrop')
const input = document.getElementById('search-input')
const results = document.getElementById('search-results')
const empty = document.getElementById('search-empty')
const trigger = document.getElementById('search-trigger')
const filtersRoot = document.getElementById('search-filters')

if (!modal || !backdrop || !input || !results || !empty || !trigger) {
  // Search UI not mounted (e.g. partial render)
} else {
  function setActiveFilterButton(key) {
    if (!filtersRoot) {
      return
    }
    for (const button of filtersRoot.querySelectorAll('[data-search-filter]')) {
      const value = button.getAttribute('data-search-filter') ?? ''
      button.classList.toggle('search-filter--active', value === key)
    }
  }

  if (filtersRoot) {
    filtersRoot.addEventListener('click', event => {
      const target = event.target
      if (!(target instanceof HTMLElement)) {
        return
      }
      const button = target.closest('[data-search-filter]')
      if (!(button instanceof HTMLButtonElement)) {
        return
      }
      activeCollectionFilter = button.getAttribute('data-search-filter') ?? ''
      setActiveFilterButton(activeCollectionFilter)
      input.dispatchEvent(new Event('input'))
    })
  }

  function openSearch() {
    modal.classList.remove('hidden')
    input.placeholder = searchStrings.searchPlaceholder
    input.focus()
    loadPagefind()
  }

  function closeSearch() {
    modal.classList.add('hidden')
    input.value = ''
    results.innerHTML = ''
    results.appendChild(empty)
    empty.textContent = searchStrings.searchEmptyLabel
  }

  trigger.addEventListener('click', openSearch)
  backdrop.addEventListener('click', closeSearch)

  document.addEventListener('keydown', e => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
      e.preventDefault()
      openSearch()
    }
    if (e.key === 'Escape') closeSearch()
  })

  let debounce
  input.addEventListener('input', async () => {
    clearTimeout(debounce)
    const q = input.value.trim()
    if (!q) {
      results.innerHTML = ''
      results.appendChild(empty)
      empty.textContent = searchStrings.searchEmptyLabel
      return
    }
    debounce = setTimeout(async () => {
      const pf = await loadPagefind()
      const activeVersionPath = getActiveVersionPath(window.location.pathname)
      if (!pf) {
        empty.textContent = searchStrings.searchUnavailableLabel
        results.innerHTML = ''
        results.appendChild(empty)
        return
      }
      const search = await pf.search(q, pagefindSearchOptions())
      if (!search.results.length) {
        empty.textContent = searchStrings.searchNoResultsLabel.replace('{query}', q)
        results.innerHTML = ''
        results.appendChild(empty)
        return
      }
      const rawItems = await Promise.all(search.results.slice(0, 30).map(r => r.data()))
      const items = rawItems
        .filter(item => !isExcludedSearchResult(item))
        .filter(item => (activeVersionPath ? inActiveVersion(item.url, activeVersionPath) : true))
      if (!items.length) {
        empty.textContent = searchStrings.searchNoResultsLabel.replace('{query}', q)
        results.innerHTML = ''
        results.appendChild(empty)
        return
      }
      results.innerHTML = items
        .slice(0, 8)
        .map(item => {
          const title = item.meta?.title ?? searchStrings.untitledLabel
          const excerpt = item.excerpt ?? ''
          return (
            '<a href="' +
            item.url +
            '" class="search-result" data-search-result>' +
            '<span class="search-result__title">' +
            title +
            '</span>' +
            '<span class="search-result__excerpt">' +
            excerpt +
            '</span>' +
            '</a>'
          )
        })
        .join('')
    }, 150)
  })
}
</script>
