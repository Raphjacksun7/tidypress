---
export interface Props {
  code: string
  align?: 'left' | 'center' | 'right'
}

const { code, align = 'left' } = Astro.props
const alignClass =
  align === 'center'
    ? 'mermaid-wrapper--center'
    : align === 'right'
      ? 'mermaid-wrapper--right'
      : 'mermaid-wrapper--left'
---
<div class:list={['mermaid-wrapper', alignClass]} data-mermaid={code}>
  <p class="mermaid-source dm-mermaid-loading" aria-hidden="true">Loading diagram…</p>
</div>

<script>
// @ts-nocheck
import mermaid from 'mermaid'

/**
 * Mirrors Base/ThemeToggle theme precedence: explicit data-theme, then system.
 */
function isPageDark() {
  const themeOverride = document.documentElement.getAttribute('data-theme')
  if (themeOverride === 'dark') return true
  if (themeOverride === 'light') return false
  return window.matchMedia('(prefers-color-scheme: dark)').matches
}

function cssToken(name, fallback) {
  const value = getComputedStyle(document.documentElement).getPropertyValue(name).trim()
  return value || fallback
}

function buildMermaidConfig() {
  const dark = isPageDark()
  const fg = cssToken('--fg', dark ? '#fafafa' : '#0a0a0a')
  const muted = cssToken('--muted', dark ? '#a1a1aa' : '#3f3f46')
  const border = cssToken('--border', dark ? '#27272a' : '#e5e5e5')
  const surface = cssToken('--surface', dark ? '#18181b' : '#f4f4f4')
  if (dark) {
    return {
      startOnLoad: false,
      theme: 'dark',
      themeVariables: {
        background: 'transparent',
        lineColor: fg,
        textColor: fg,
        primaryTextColor: fg,
        secondaryTextColor: muted,
        tertiaryTextColor: muted,
        primaryColor: surface,
        primaryBorderColor: muted,
        secondaryColor: border,
        mainBkg: surface,
        secondBkg: surface,
        tertiaryColor: border,
        nodeBorder: muted,
        clusterBkg: surface,
        titleColor: fg,
        edgeLabelBackground: 'rgba(9, 9, 10, 0.92)',
      },
      fontFamily: 'var(--font-mono, ui-monospace, monospace)',
    }
  }
  return {
    startOnLoad: false,
    theme: 'default',
    themeVariables: {
      background: 'transparent',
      lineColor: muted,
      textColor: fg,
      primaryTextColor: fg,
      secondaryTextColor: muted,
      tertiaryTextColor: muted,
      primaryColor: surface,
      primaryBorderColor: muted,
      secondaryColor: border,
      mainBkg: surface,
      secondBkg: surface,
      nodeBorder: muted,
      clusterBkg: surface,
      titleColor: fg,
      edgeLabelBackground: 'rgba(255, 255, 255, 0.9)',
    },
    fontFamily: 'var(--font-mono, ui-monospace, monospace)',
  }
}

async function renderAll() {
  mermaid.initialize(buildMermaidConfig())
  const wrappers = document.querySelectorAll('[data-mermaid]')
  for (const el of wrappers) {
    const code = el.getAttribute('data-mermaid') ?? ''
    if (!code.trim()) {
      el.replaceChildren()
      continue
    }
    const id = 'dm-mermaid-' + String(Math.random()).replace(/^0\./, '')
    try {
      const { svg, bindFunctions } = await mermaid.render(id, code)
      el.innerHTML = svg
      bindFunctions?.(el)
    } catch (e) {
      const msg = e instanceof Error ? e.message : String(e)
      const p = document.createElement('p')
      p.className = 'm-0 text-xs'
      p.style.color = 'var(--muted)'
      p.textContent = msg
      el.replaceChildren(p)
    }
  }
}

void renderAll()

const obs = new MutationObserver(() => {
  void renderAll()
})
obs.observe(document.documentElement, {
  attributes: true,
  attributeFilter: ['data-theme'],
})
</script>
