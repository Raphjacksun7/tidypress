---
import type { TidyPressVersion } from '@tidypress/config'

export interface Props {
  versions: TidyPressVersion[]
  selectedPath?: string
  targets?: Record<string, string>
}

const { versions = [], selectedPath, targets = {} } = Astro.props
const normalizedVersions = versions.filter(
  (version) => Boolean(version?.label) && Boolean(version?.path),
)
---
{
  normalizedVersions.length > 0 && (
    <label class="hidden sm:inline-flex items-center relative tidy-version-selector">
      <span class="sr-only">Select version</span>
      <select
        aria-label="Select version"
        class="tidy-nav-select"
        onchange="if (this.value) window.location.assign(this.value)"
      >
        {normalizedVersions.map((version) => (
          <option
            value={targets[version.path] ?? version.path}
            selected={version.path === selectedPath}
          >
            {version.label}
          </option>
        ))}
      </select>
      <span class="tidy-nav-select__chevron" aria-hidden="true">▾</span>
    </label>
  )
}
