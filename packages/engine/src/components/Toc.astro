---
export interface Props {
  headings: { depth: number; slug: string; text: string }[]
}
const { headings } = Astro.props
const filtered = headings.filter(h => h.depth === 2 || h.depth === 3)
---
{filtered.length > 0 && (
  <nav class="sticky top-12 text-sm space-y-1">
    <p class="font-bold text-xs uppercase tracking-wide mb-2">On this page</p>
    {filtered.map(({ depth, slug, text }) => (
      <a
        href={`#${slug}`}
        class:list={[
          'block py-0.5',
          depth === 3 ? 'pl-3 text-zinc-400' : 'text-zinc-500'
        ]}
      >
        {text}
      </a>
    ))}
  </nav>
)}
