---
import {
  tidyPressHomePreviewPresentation,
  isCardListLayout,
  listGapStackClass,
  listLayoutPresentation,
  resolveEntryLinkAttributes,
  type ResolvedListDisplay,
} from '@tidypress/config'
import EntryIcon from '@/components/EntryIcon.astro'
import TagList from '@/components/TagList.astro'
import type { HomePreviewItem } from '@/utils/home-preview'

interface Props {
  title: string
  items: HomePreviewItem[]
  display: ResolvedListDisplay
  showDateInList: boolean
  showDescriptionInList: boolean
  moreHref?: string
  moreLabel?: string
}

const { title, items, display, showDateInList, showDescriptionInList, moreHref, moreLabel } = Astro.props
const stackClass = listGapStackClass(display.gap)
const cardPresentation = listLayoutPresentation('card')
const listPresentation = listLayoutPresentation('list')
const previewPresentation = tidyPressHomePreviewPresentation
const shouldRenderCardRows = isCardListLayout(display.layout) && display.showDescription
---
{items.length > 0 && (
  <section class={previewPresentation.sectionClass}>
    <p class="tidy-home-section-title">{title}</p>
    {shouldRenderCardRows ? (
      <ul class:list={[cardPresentation.containerClass, stackClass]}>
        {items.map(item => {
          const iconSrc = item.icon ?? display.icon
          const linkAttrs = resolveEntryLinkAttributes(item)
          return (
            <li>
              <a href={item.href} class={previewPresentation.cardLinkClass} {...linkAttrs}>
                {iconSrc && (
                  <EntryIcon src={iconSrc} />
                )}
                <div class={previewPresentation.cardContentClass}>
                  <span class={previewPresentation.cardTitleClass}>{item.title}</span>
                  {display.showDescription && item.description && (
                    <p class={previewPresentation.cardDescriptionClass}>{item.description}</p>
                  )}
                  {display.showTags && item.tags && item.tags.length > 0 && (
                    <TagList tags={item.tags} />
                  )}
                  {showDateInList && item.dateLabel && (
                    <p class={previewPresentation.cardMetaClass}>{item.dateLabel}</p>
                  )}
                </div>
              </a>
            </li>
          )
        })}
      </ul>
    ) : (
      <ul class:list={[stackClass]}>
        {items.map(item => {
          const linkAttrs = resolveEntryLinkAttributes(item)
          return (
          <li>
            <a
              href={item.href}
              data-no-hover
              class:list={[previewPresentation.listLinkClass, listPresentation.rowClass]}
              {...linkAttrs}
            >
              <span class={listPresentation.titleClass} {...{ [previewPresentation.listTitleDataAttr]: true }}>{item.title}</span>
              {showDateInList && item.dateLabel && (
                <span class={listPresentation.metaClass}>{item.dateLabel}</span>
              )}
              {showDescriptionInList && item.description && (
                <span class:list={[listPresentation.metaClass, previewPresentation.listDescriptionClass]}>{item.description}</span>
              )}
            </a>
          </li>
        )})}
      </ul>
    )}
    {moreHref && moreLabel && (
      <p class={previewPresentation.moreWrapperClass}>
        <a href={moreHref} class={previewPresentation.moreLinkClass} data-home-more-link>{moreLabel}</a>
      </p>
    )}
  </section>
)}
