---
import {
  isCardListLayout,
  listGapStackClass,
  listLayoutPresentation,
  type ResolvedListDisplay,
} from '@docsmint/config'
import EntryIcon from '@/components/EntryIcon.astro'
import TagList from '@/components/TagList.astro'
import type { HomePreviewItem } from '@/utils/home-preview'

interface Props {
  title: string
  items: HomePreviewItem[]
  display: ResolvedListDisplay
  showDateInList: boolean
  showDescriptionInList: boolean
  moreHref?: string
  moreLabel?: string
}

const { title, items, display, showDateInList, showDescriptionInList, moreHref, moreLabel } = Astro.props
const stackClass = listGapStackClass(display.gap)
const presentation = listLayoutPresentation(display.layout)
const listPresentation = listLayoutPresentation('list')
const shouldRenderCardRows = isCardListLayout(display.layout) && display.showDescription
---
{items.length > 0 && (
  <section class="space-y-3">
    <p class="text-sm font-bold text-zinc-500">{title}</p>
    {shouldRenderCardRows ? (
      <ul class:list={[presentation.containerClass, stackClass]}>
        {items.map(item => {
          const iconSrc = item.icon ?? display.icon
          return (
            <li>
              <a href={item.href} class="group home-card-row" style="text-decoration:none">
                {iconSrc && (
                  <EntryIcon src={iconSrc} />
                )}
                <div class="min-w-0">
                  <span class="home-card-title">{item.title}</span>
                  {display.showDescription && item.description && (
                    <p class="home-card-description">{item.description}</p>
                  )}
                  {display.showTags && item.tags && item.tags.length > 0 && (
                    <TagList tags={item.tags} />
                  )}
                  {showDateInList && item.dateLabel && (
                    <p class="home-card-meta">{item.dateLabel}</p>
                  )}
                </div>
              </a>
            </li>
          )
        })}
      </ul>
    ) : (
      <ul class:list={[stackClass]}>
        {items.map(item => (
          <li>
            <a href={item.href} data-no-hover class:list={['group', listPresentation.rowClass]} style="text-decoration:none">
              <span class={listPresentation.titleClass} data-writing-title>{item.title}</span>
              {showDateInList && item.dateLabel && (
                <span class:list={[listPresentation.metaClass, listPresentation.metaToneClass]}>{item.dateLabel}</span>
              )}
              {showDescriptionInList && item.description && (
                <span class:list={[listPresentation.metaClass, listPresentation.metaToneClass, 'hidden', 'sm:block']}>{item.description}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
    {moreHref && moreLabel && (
      <p class="pt-1">
        <a href={moreHref} class="text-xs" data-home-more-link>{moreLabel}</a>
      </p>
    )}
  </section>
)}
