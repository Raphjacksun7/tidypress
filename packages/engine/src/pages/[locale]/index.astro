---
import Base from '../../layouts/Base.astro'
import { getCollection } from 'astro:content'
import { getConfig } from '../../config/getConfig'
import { sortDocs } from '../../domain/content/sortDocs'
import BrandIcon from '../../components/BrandIcon.astro'
import { onlyPublished } from '../../domain/content/published'
import { getUiStrings, localizeEntries, resolveLocale, withLocalePrefix } from '../../i18n/locale'
import { getCollectionBasePath, getCollectionEntryPath, isCollectionEnabled } from '../../domain/content/collections'

export async function getStaticPaths() {
  const rawSite = (await import('../../../docsmint.config.ts')).default
  const site = getConfig(rawSite)
  const locales = site.i18n?.locales ?? []
  return locales.map((locale) => ({ params: { locale }, props: { locale } }))
}

const { locale } = Astro.props
const LIMIT = 5

const rawWriting = onlyPublished(await getCollection('writing'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
const rawDocs = sortDocs(onlyPublished(await getCollection('docs')))

const rawSite = (await import('../../../docsmint.config.ts')).default
const site = getConfig(rawSite)
const localeState = resolveLocale(`/${locale}`, site.i18n)
const strings = getUiStrings(site, localeState)
const allWriting = localizeEntries(rawWriting, localeState, locale).map(item => ({ ...item.entry, id: item.slug }))
const writing = allWriting.slice(0, LIMIT)
const moreWriting = allWriting.length > LIMIT
const allDocs = sortDocs(localizeEntries(rawDocs, localeState, locale).map(item => ({ ...item.entry, id: item.slug })))
const docs = allDocs.slice(0, LIMIT)
const moreDocs = allDocs.length > LIMIT
const docsEnabled = isCollectionEnabled(site, 'docs')
const writingEnabled = isCollectionEnabled(site, 'writing')
const writingBasePath = withLocalePrefix(getCollectionBasePath(site, 'writing'), locale)

const fmt = new Intl.DateTimeFormat(
  site.dateLocale ?? 'en-US',
  { ...(site.dateFormat ?? { year: 'numeric', month: 'short', day: 'numeric' }), timeZone: 'UTC' }
)
---
<Base title={site.name} description={site.description}>
  <div class="max-w-3xl mx-auto px-8 py-16 space-y-16">
    <section>
      <h1 class="text-2xl font-bold tracking-tight mb-3 inline-flex items-center gap-2">
        {site.branding?.icon && <BrandIcon src={site.branding.icon} sizeClass="size-[1.08em]" />}
        {site.name}
      </h1>
      <p class="text-sm text-zinc-500 leading-relaxed">{site.description}</p>
    </section>

    {writingEnabled && writing.length > 0 && (
      <section class="space-y-3">
        <p class="text-sm font-bold text-zinc-500">{strings.writingTitle}</p>
        <ul class="space-y-2">
          {writing.map(post => (
            <li>
              <a href={withLocalePrefix(getCollectionEntryPath(site, 'writing', post.id), locale)}
                 data-no-hover
                 class="group flex items-center justify-between gap-4"
                 style="text-decoration:none">
                <span class="text-sm underline underline-offset-4 group-hover:no-underline group-hover:px-1 transition-all" data-writing-title>
                  {post.data.title}
                </span>
                <span class="text-xs text-zinc-400 shrink-0">{fmt.format(post.data.date)}</span>
              </a>
            </li>
          ))}
        </ul>
        {moreWriting && (
          <p class="pt-1">
            <a href={writingBasePath} class="text-xs text-zinc-400">{strings.allWritingLabel}</a>
          </p>
        )}
      </section>
    )}

    {docsEnabled && docs.length > 0 && (
      <section class="space-y-3">
        <p class="text-sm font-bold text-zinc-500">{strings.docsTitle}</p>
        <ul class="space-y-2">
          {docs.map(doc => (
            <li>
              <a href={withLocalePrefix(getCollectionEntryPath(site, 'docs', doc.id), locale)}
                 data-no-hover
                 class="group flex items-center justify-between gap-4"
                 style="text-decoration:none">
                <span class="text-sm underline underline-offset-4 group-hover:no-underline group-hover:px-1 transition-all" data-writing-title>
                  {doc.data.title}
                </span>
              </a>
            </li>
          ))}
        </ul>
        {moreDocs && (
          <p class="pt-1">
            <a href={withLocalePrefix(getCollectionEntryPath(site, 'docs', allDocs[0].id), locale)} class="text-xs text-zinc-400">{strings.allDocsLabel}</a>
          </p>
        )}
      </section>
    )}
  </div>
</Base>
