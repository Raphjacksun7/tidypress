---
import { getCollection, render } from 'astro:content'
import Doc from '../../layouts/Doc.astro'
import Tooltip from '../../components/Tooltip.astro'
import FileTree from '../../components/FileTree.astro'
import Callout from '../../components/Callout.astro'
import Image from '../../components/Image.astro'
import Tabs from '../../components/Tabs.astro'
import Tab from '../../components/Tab.astro'
import Mermaid from '../../components/Mermaid.astro'
import { getConfig } from '../../config/getConfig'
import { isSearchExcluded } from '../../search/exclusion'
import { onlyPublished } from '../../domain/content/published'
import {
  getCollectionBasePath,
  getCollectionEntryPath,
  isCollectionEnabled,
} from '../../domain/content/collections'
import { stripDocExtension, versionContentPrefix } from '../../routing/versioning'

export async function getStaticPaths() {
  const rawSite = (await import('../../../docsmint.config.ts')).default
  const site = getConfig(rawSite)
  if (!isCollectionEnabled(site, 'docs')) {
    return []
  }
  const docs = onlyPublished(await getCollection('docs'))
  const docsBasePath = getCollectionBasePath(site, 'docs')
  const basePaths = docs.map(entry => ({
    params: { slug: stripDocExtension(entry.id) },
    props: { entry, isVersionRoot: false },
  }))
  const existingSlugs = new Set(basePaths.map(pathEntry => pathEntry.params.slug))

  const versionRootPaths = (site.versions ?? [])
    .map(version => {
      const prefix = versionContentPrefix(version.path, docsBasePath)
      if (!prefix || existingSlugs.has(prefix)) {
        return undefined
      }
      const firstEntry = docs.find(entry => {
        const docId = stripDocExtension(entry.id)
        return docId === prefix || docId.startsWith(`${prefix}/`)
      })
      if (!firstEntry) {
        return undefined
      }
      return {
        params: { slug: prefix },
        props: { entry: firstEntry, isVersionRoot: true },
      }
    })
    .filter(Boolean)

  return [...basePaths, ...versionRootPaths]
}

const { entry } = Astro.props
const rawSite = (await import('../../../docsmint.config.ts')).default
const site = getConfig(rawSite)
if (!isCollectionEnabled(site, 'docs')) {
  return Astro.redirect('/404', 302)
}
const { Content, headings } = await render(entry)
const pagePath = getCollectionEntryPath(site, 'docs', entry.id)
const pagefindIgnore = entry.data.search === false || isSearchExcluded(site, pagePath)
---
<Doc
  title={entry.data.title}
  description={entry.data.description}
  headings={headings}
  editPath={pagePath}
>
  <div data-pagefind-ignore={pagefindIgnore ? true : undefined}>
    <Content
      components={{
        Tooltip,
        FileTree,
        Callout,
        img: Image,
        Tabs,
        Tab,
        Mermaid,
      }}
    />
  </div>
</Doc>
