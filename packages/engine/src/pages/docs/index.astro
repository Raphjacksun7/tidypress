---
import { getCollection, render } from 'astro:content'
import { sortDocs } from '../../domain/content/sortDocs'
import { getConfig } from '../../config/getConfig'
import Doc from '../../layouts/Doc.astro'
import Tooltip from '../../components/Tooltip.astro'
import FileTree from '../../components/FileTree.astro'
import Callout from '../../components/Callout.astro'
import Image from '../../components/Image.astro'
import Tabs from '../../components/Tabs.astro'
import Tab from '../../components/Tab.astro'
import Mermaid from '../../components/Mermaid.astro'
import { isSearchExcluded } from '../../search/exclusion'
import { onlyPublished } from '../../domain/content/published'
import { getCollectionBasePath, getCollectionEntryPath, isCollectionEnabled } from '../../domain/content/collections'
import { stripDocExtension, versionContentPrefix } from '../../routing/versioning'

const rawSite = (await import('../../../docsmint.config.ts')).default
const site = getConfig(rawSite)

if (!isCollectionEnabled(site, 'docs')) {
  return Astro.redirect('/404', 302)
}

const docsBasePath = getCollectionBasePath(site, 'docs')
const docs = sortDocs(onlyPublished(await getCollection('docs')))
const firstVersionPrefix = site.versions?.[0]
  ? versionContentPrefix(site.versions[0].path, docsBasePath)
  : undefined
const firstByVersion = firstVersionPrefix
  ? docs.find(entry => {
      const id = stripDocExtension(entry.id)
      return id === firstVersionPrefix || id.startsWith(`${firstVersionPrefix}/`)
    })
  : undefined
const first = firstByVersion ?? docs[0]

if (!first) {
  return Astro.redirect('/404', 302)
}

const { Content, headings } = await render(first)
const firstDocHref = getCollectionEntryPath(site, 'docs', first.id)
const pagePath = getCollectionEntryPath(site, 'docs', first.id)
const pagefindIgnore = first.data.search === false || isSearchExcluded(site, pagePath)
---
<Doc
  title={first.data.title}
  description={first.data.description}
  headings={headings}
  editPath={pagePath}
>
  <div data-pagefind-ignore={pagefindIgnore ? true : undefined}>
    <script is:inline define:vars={{ docsBasePath, firstDocHref }}>
      if (location.pathname === docsBasePath || location.pathname === `${docsBasePath}/`) {
        history.replaceState(null, '', firstDocHref)
      }
    </script>
    <Content
      components={{
        Tooltip,
        FileTree,
        Callout,
        img: Image,
        Tabs,
        Tab,
        Mermaid,
      }}
    />
  </div>
</Doc>
