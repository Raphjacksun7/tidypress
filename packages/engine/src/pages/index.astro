---
import Base from '../layouts/Base.astro'
import { getCollection } from 'astro:content'
import { getConfig } from '../config/getConfig'
import { sortDocs } from '../utils/sortDocs'
import BrandIcon from '../components/BrandIcon.astro'

const LIMIT = 5

const allWriting = (await getCollection('writing'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
const writing = allWriting.slice(0, LIMIT)
const moreWriting = allWriting.length > LIMIT

const allDocs = sortDocs(await getCollection('docs'))
const docs = allDocs.slice(0, LIMIT)
const moreDocs = allDocs.length > LIMIT

const rawSite = (await import('../../docsmint.config.ts')).default
const site = getConfig(rawSite)
const docsEnabled = site.sections?.docs?.enabled ?? true
const writingEnabled = site.sections?.writing?.enabled ?? true
const docsBasePath = site.sections?.docs?.basePath ?? '/docs'
const writingBasePath = site.sections?.writing?.basePath ?? '/writing'

const fmt = new Intl.DateTimeFormat(
  site.dateLocale ?? 'en-US',
  { ...(site.dateFormat ?? { year: 'numeric', month: 'short', day: 'numeric' }), timeZone: 'UTC' }
)
---
<Base title={site.name} description={site.description}>
  <div class="max-w-3xl mx-auto px-8 py-16 space-y-16">

    <!-- Identity -->
    <section>
      <h1 class="text-2xl font-bold tracking-tight mb-3 inline-flex items-center gap-2">
        {site.branding?.icon && <BrandIcon src={site.branding.icon} sizeClass="size-[1.08em]" />}
        {site.name}
      </h1>
      <p class="text-sm text-zinc-500 leading-relaxed">{site.description}</p>
    </section>

    <!-- Writing -->
    {writingEnabled && writing.length > 0 && (
      <section class="space-y-3">
        <p class="text-sm font-bold text-zinc-500">Writing</p>
        <ul class="space-y-2">
          {writing.map(post => (
            <li>
              <a href={`${writingBasePath}/${post.id}`}
                 data-no-hover
                 class="group flex items-center justify-between gap-4"
                 style="text-decoration:none">
                <span class="text-sm underline underline-offset-4
                             group-hover:no-underline group-hover:px-1
                             transition-all" data-writing-title>
                  {post.data.title}
                </span>
                <span class="text-xs text-zinc-400 shrink-0">
                  {fmt.format(post.data.date)}
                </span>
              </a>
            </li>
          ))}
        </ul>
        {moreWriting && (
          <p class="pt-1">
            <a href={writingBasePath} class="text-xs text-zinc-400">all writing →</a>
          </p>
        )}
      </section>
    )}

    <!-- Docs -->
    {docsEnabled && docs.length > 0 && (
      <section class="space-y-3">
        <p class="text-sm font-bold text-zinc-500">Docs</p>
        <ul class="space-y-2">
          {docs.map(doc => (
            <li>
              <a href={`${docsBasePath}/${doc.id}`}
                 data-no-hover
                 class="group flex items-center justify-between gap-4"
                 style="text-decoration:none">
                <span class="text-sm underline underline-offset-4
                             group-hover:no-underline group-hover:px-1
                             transition-all" data-writing-title>
                  {doc.data.title}
                </span>
                {doc.data.description && (
                  <span class="text-xs text-zinc-400 shrink-0 hidden sm:block">
                    {doc.data.description}
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
        {moreDocs && (
          <p class="pt-1">
            <a href={`${docsBasePath}/${allDocs[0].id}`} class="text-xs text-zinc-400">all docs →</a>
          </p>
        )}
      </section>
    )}

  </div>

  <!-- Footer -->
  <footer class="max-w-3xl mx-auto px-8 py-6 mt-4">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-t border-zinc-100 pt-6">
      <p class="text-xs text-zinc-400">&copy; {new Date().getFullYear()} {site.name}</p>
      <div class="flex items-center gap-4">
        {(site.footer || []).map(({ label, href }: { label: string; href: string }) => (
          <a href={href} class="text-xs text-zinc-400">{label}</a>
        ))}
      </div>
    </div>
  </footer>
</Base>
