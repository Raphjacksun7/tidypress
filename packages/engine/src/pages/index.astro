---
import Base from '@/layouts/Base.astro'
import BrandIcon from '@/components/BrandIcon.astro'
import HeroBlock from '@/components/HeroBlock.astro'
import HomePreviewSection from '@/components/HomePreviewSection.astro'
import { getConfig } from '@/config/getConfig'
import { getUiStrings, resolveLocale } from '@/i18n/locale'
import {
  buildHomePreviewItems,
  getHomeSectionKeys,
  homeSectionMoreLabel,
  homeSectionTitle,
  homePreviewListFlags,
  resolveHomeDisplayForCollection,
} from '@/utils/home-preview'

const rawSite = (await import('@site-config')).default
const site = getConfig(rawSite)
const siteBaseUrl = site.siteUrl ? site.siteUrl.replace(/\/$/, '') : undefined
const strings = getUiStrings(site, resolveLocale(Astro.url.pathname, site.i18n))
const dateFormatter = new Intl.DateTimeFormat(
  site.dateLocale ?? 'en-US',
  { ...(site.dateFormat ?? { year: 'numeric', month: 'short', day: 'numeric' }), timeZone: 'UTC' },
)

const sections = []
for (const collectionKey of getHomeSectionKeys(site)) {
  const { items, moreHref } = await buildHomePreviewItems(site, collectionKey, { dateFormatter })
  if (items.length === 0) {
    continue
  }
  sections.push({
    key: collectionKey,
    title: homeSectionTitle(site, collectionKey, strings),
    ...homePreviewListFlags(site, collectionKey),
    items,
    moreHref,
    moreLabel: moreHref ? homeSectionMoreLabel(site, collectionKey, strings) : undefined,
    display: resolveHomeDisplayForCollection(site, collectionKey),
  })
}
---
<Base title={site.name} description={site.description}>
  <div class="max-w-3xl mx-auto px-8 py-16 space-y-16">

    <section>
      <h1 class="text-2xl font-bold tracking-tight mb-3 inline-flex items-center gap-2">
        {site.branding?.icon && <BrandIcon src={site.branding.icon} sizeClass="size-[1.08em]" />}
        {site.name}
      </h1>
      <p class="dm-site-description">{site.description}</p>
      {site.hero && <HeroBlock hero={site.hero} imageBaseUrl={siteBaseUrl} />}
    </section>

    {sections.map(section => (
      <HomePreviewSection
        title={section.title}
        items={section.items}
        display={section.display}
        showDateInList={section.showDateInList}
        showDescriptionInList={section.showDescriptionInList}
        moreHref={section.moreHref}
        moreLabel={section.moreLabel}
      />
    ))}

  </div>
</Base>
