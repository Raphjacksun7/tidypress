---
import { getCollection, render } from 'astro:content'
import Base from '../layouts/Base.astro'
import { getConfig } from '../config/getConfig'
import { isSearchExcluded } from '../utils/searchExclusion'

export async function getStaticPaths() {
  const rawSite = (await import('../../docsmint.config.ts')).default
  const site = getConfig(rawSite)
  const customPages = site.pages ?? []

  return customPages.map(page => ({
    params: { customPage: page.slug },
  }))
}

const pageSlug = Astro.params.customPage
const rawSite = (await import('../../docsmint.config.ts')).default
const site = getConfig(rawSite)
const pages = await getCollection('pages')
const entry = pages.find(candidate => candidate.id === pageSlug)

if (!entry) {
  throw new Error(
    `Missing custom page content for slug "${pageSlug}". Add src/content/pages/${pageSlug}.md`,
  )
}

const { Content } = await render(entry)
const pagePath = `/${pageSlug}`
const pagefindIgnore = entry.data.search === false || isSearchExcluded(site, pagePath)
---
<Base title={entry.data.title ?? pageSlug} description={entry.data.description}>
  <div class="max-w-3xl mx-auto px-8 py-16">
    <article class="prose" data-pagefind-ignore={pagefindIgnore ? true : undefined}>
      <h1>{entry.data.title ?? pageSlug}</h1>
      <Content />
    </article>
  </div>
</Base>
