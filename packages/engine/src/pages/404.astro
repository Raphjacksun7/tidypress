---
import Base from '../layouts/Base.astro'
---
<Base title="404">
  <div class="max-w-3xl mx-auto px-8 py-24 mt-24 flex flex-col gap-8">

    <div class="flex flex-col gap-3">
      <p class="text-sm font-bold">404 — not found</p>
      <p class="text-sm" style="color:var(--muted)">
        This page does not exist or has been moved.
      </p>
    </div>

    <a href="/"
       style="text-decoration:none"
       class="group inline-flex items-center gap-2 text-sm w-fit">
      <span style="color:var(--muted)" class="group-hover:text-inherit transition-colors">←</span>
      <span class="underline underline-offset-4 group-hover:no-underline">back home</span>
    </a>

  </div>
</Base>
