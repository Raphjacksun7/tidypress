---
import '../styles/global.css'
import Nav from '@/components/Nav.astro'
import Footer from '@/components/Footer.astro'
import { getConfig } from '@/config/getConfig'
import { getUiStrings, resolveLocale } from '@/i18n/locale'
import { getEffectiveSiteUrl, resolveCapabilityFlags } from '@tidypress/config'

export interface Props {
  title: string
  description?: string
  noindex?: boolean
  tags?: string[]
  ogImage?: string
}

const { title, description, noindex = false, tags = [], ogImage } = Astro.props
const rawSite = (await import('@site-config')).default
const site = getConfig(rawSite)
const capabilityFlags = resolveCapabilityFlags(site)
const localeState = resolveLocale(Astro.url.pathname, site.i18n)
const strings = getUiStrings(site, localeState)
const htmlLang = localeState.activeLocale ?? site.i18n?.defaultLocale ?? 'en'
const faviconHref = site.branding?.favicon ?? site.branding?.icon
const faviconIsSvg = Boolean(faviconHref && /\.svg(?:$|[?#])/i.test(faviconHref))
const themingEnabled = capabilityFlags.theming === true
const themeMode = themingEnabled ? (site.theme?.mode ?? 'guardrailed') : 'guardrailed'
const themePreset = site.theme?.preset ?? 'baseline'
const themeTokens = site.theme?.tokens ?? { light: {}, dark: {} }
const lightTheme = themeTokens.light ?? {}
const darkTheme = themeTokens.dark ?? {}
const themeCssVariables = `
:root {
  --bg: ${lightTheme.bg};
  --fg: ${lightTheme.fg};
  --muted: ${lightTheme.muted};
  --border: ${lightTheme.border};
  --surface: ${lightTheme.surface};
  --code-bg: ${lightTheme.codeBg};
  --code-fg: ${lightTheme.codeFg};
}
[data-theme="dark"] {
  --bg: ${darkTheme.bg};
  --fg: ${darkTheme.fg};
  --muted: ${darkTheme.muted};
  --border: ${darkTheme.border};
  --surface: ${darkTheme.surface};
  --code-bg: ${darkTheme.codeBg};
  --code-fg: ${darkTheme.codeFg};
}
`

const pageTitle = title === site.name ? site.name : `${title} — ${site.name}`
const metaDescription = description || site.description || ''

const siteBaseUrl = getEffectiveSiteUrl(site)
const canonicalHref = siteBaseUrl ? `${siteBaseUrl}${Astro.url.pathname}` : undefined
function resolveOgImageHref(imagePath: string | undefined, baseUrl: string | undefined): string | undefined {
  if (!imagePath) {
    return baseUrl ? `${baseUrl}/og.svg` : undefined
  }
  if (/^https?:\/\//i.test(imagePath)) {
    return imagePath
  }
  if (!baseUrl) {
    return imagePath
  }
  return `${baseUrl}${imagePath.startsWith('/') ? imagePath : `/${imagePath}`}`
}

const ogImageHref = resolveOgImageHref(ogImage, siteBaseUrl)
---
<!doctype html>
<html
  lang={htmlLang}
  data-text-scale={site.typography?.scale ?? 'medium'}
  data-theme-mode={themeMode}
  data-theme-preset={themePreset}
  data-pagefind-ignore={noindex ? 'all' : undefined}
>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {noindex
    ? <meta name="robots" content="noindex, nofollow" />
    : <meta name="robots" content="index, follow" />
  }
  <title>{pageTitle}</title>
  <meta name="description" content={metaDescription} />
  {tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
  {canonicalHref && <link rel="canonical" href={canonicalHref} />}

  <meta property="og:site_name" content={site.name} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={metaDescription} />
  {canonicalHref && <meta property="og:url" content={canonicalHref} />}
  {ogImageHref && <meta property="og:image" content={ogImageHref} />}

  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={metaDescription} />
  {ogImageHref && <meta name="twitter:image" content={ogImageHref} />}
  {faviconHref && (
    <link id="tidypress-favicon" rel="icon" type={faviconIsSvg ? 'image/svg+xml' : undefined} href={faviconHref} />
  )}
  <style is:inline>{themeCssVariables}</style>
  {site.analytics?.type === 'plausible' && site.analytics.endpoint && site.analytics.siteId && (
    <script defer data-domain={site.analytics.siteId} src={site.analytics.endpoint}></script>
  )}
  {site.analytics?.type === 'umami' && site.analytics.endpoint && site.analytics.siteId && (
    <script defer src={site.analytics.endpoint} data-website-id={site.analytics.siteId}></script>
  )}
  {site.analytics?.type === 'fathom' && site.analytics.endpoint && site.analytics.siteId && (
    <script defer src={site.analytics.endpoint} data-site={site.analytics.siteId}></script>
  )}
  <!-- Runs before first paint to keep theme and UI aligned. -->
  <script is:inline define:vars={{ themingEnabled }}>
    (function() {
      if (!themingEnabled) {
        document.documentElement.setAttribute('data-theme', 'light')
        return
      }
      var t = localStorage.getItem('theme')
      var dark = t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)
      document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light')
    })()
  </script>
</head>
<body class="min-h-screen">
  <Nav site={site} />
  <slot />
  <Footer
    site={site}
    locales={localeState.locales}
    activeLocale={localeState.activeLocale}
    defaultLocale={localeState.defaultLocale}
    languageLabel={strings.languageLabel}
  />

  <script is:inline define:vars={{ strings }}>
    document.querySelectorAll('pre').forEach(pre => {
      const parent = pre.parentNode
      if (!parent) return

      const wrapper = document.createElement('div')
      wrapper.style.cssText = 'position:relative'
      parent.insertBefore(wrapper, pre)
      wrapper.appendChild(pre)

      const btn = document.createElement('button')
      btn.textContent = strings.copyLabel
      btn.setAttribute('aria-label', strings.copyLabel)
      btn.className = 'copy-btn'
      wrapper.appendChild(btn)

      wrapper.addEventListener('mouseenter', () => { btn.style.opacity = '1' })
      wrapper.addEventListener('mouseleave', () => { btn.style.opacity = '0' })

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code')
        const text = code?.innerText ?? ''
        try {
          await navigator.clipboard.writeText(text)
        } catch {
          // Ignore clipboard permission failures; keep UI stable.
        }
        btn.textContent = strings.copiedLabel
        setTimeout(() => { btn.textContent = strings.copyLabel }, 2000)
      })
    })
  </script>
</body>
</html>
