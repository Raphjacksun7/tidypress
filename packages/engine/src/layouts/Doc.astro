---
import Base from './Base.astro'
import Sidebar from '../components/Sidebar.astro'
import Toc from '../components/Toc.astro'
import { getConfig } from '../config/getConfig'

export interface Props {
  title: string
  description?: string
  headings?: { depth: number; slug: string; text: string }[]
  editPath?: string
}

const { title, description, headings = [], editPath } = Astro.props
const rawSite = (await import('../../docsmint.config.ts')).default
const site = getConfig(rawSite)

const editBaseUrl = site.repository?.url
const editBranch = site.repository?.branch ?? 'main'
const editContentPath = site.repository?.editPath
const normalizedEditPath = editPath?.replace(/^\//, '')
const resolvedEditUrl =
  editBaseUrl && editContentPath && normalizedEditPath
    ? `${editBaseUrl.replace(/\/$/, '')}/edit/${editBranch}/${editContentPath.replace(/^\//, '').replace(/\/$/, '')}/${normalizedEditPath}.md`
    : undefined
---
<Base title={title} description={description}>

  <!-- Mobile sidebar toggle -->
  <div class="md:hidden border-b px-8 py-3" style="border-color:var(--border)">
    <details>
      <summary class="text-xs font-bold uppercase tracking-wide cursor-pointer"
               style="list-style:none; color:var(--muted)">
        On this page
      </summary>
      <div class="pt-3 pb-1">
        <Sidebar />
      </div>
    </details>
  </div>

  <div class="max-w-screen-xl mx-auto px-8 py-12 flex gap-16">

    <!-- Sidebar — desktop only -->
    <aside class="w-52 shrink-0 hidden md:block">
      <Sidebar />
    </aside>

    <!-- Main content -->
    <main class="min-w-0 flex-1 max-w-2xl">
      <article class="prose">
        <slot />
      </article>
    </main>

    <!-- TOC — large screens only -->
    {headings.length > 0 && (
      <aside class="w-44 shrink-0 hidden lg:block">
        <Toc headings={headings} />
        {resolvedEditUrl && (
          <p class="mt-4 text-xs">
            <a href={resolvedEditUrl} target="_blank" rel="noopener noreferrer" class="text-zinc-500">
              Edit this page →
            </a>
          </p>
        )}
      </aside>
    )}

  </div>
</Base>
