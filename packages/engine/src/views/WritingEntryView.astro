---
import Base from '@/layouts/Base.astro'
import ChapterNav from '@/components/ChapterNav.astro'
import ProseContent from '@/components/ProseContent.astro'
import TagList from '@/components/TagList.astro'
import type { RouteViewBundle } from '@/collections/bundle'
import { getUiStrings, resolveLocale } from '@/i18n/locale'

interface Props {
  bundle: RouteViewBundle
  Content: any
  mdxComponents: Record<string, any>
}

const { bundle, Content, mdxComponents } = Astro.props
const showTags = bundle.site.writing?.entry?.showTags === true
const entryTags = bundle.entryMeta?.tags ?? []
const strings = getUiStrings(
  bundle.site,
  resolveLocale(bundle.route.path, bundle.site.i18n),
)
---
<Base
  title={bundle.title}
  description={bundle.description}
  tags={entryTags}
  ogImage={bundle.entryMeta?.ogImage}
>
  <div class="max-w-3xl mx-auto px-8 py-16">
    <div class="mb-10">
      <div class="tidy-writing-entry-meta">
        {bundle.entryMeta?.dateLabel && <span>{bundle.entryMeta.dateLabel}</span>}
        {bundle.entryMeta?.readingTimeLabel && <span>{bundle.entryMeta.readingTimeLabel}</span>}
        {bundle.entryMeta?.author && <span>— {bundle.entryMeta.author}</span>}
      </div>
      <h1 class="text-2xl font-bold tracking-tight">{bundle.title}</h1>
      {bundle.description && <p class="tidy-writing-entry-description">{bundle.description}</p>}
      {showTags && entryTags.length > 0 && (
        <div class="pt-3">
          <TagList tags={entryTags} />
        </div>
      )}
    </div>
    <ProseContent
      Content={Content}
      components={mdxComponents}
      pagefindIgnore={bundle.pagefindIgnore}
      pagefindCollection={bundle.route.collectionKey}
    />
    {bundle.entryMeta?.showChapterNavBottom && bundle.entryMeta.chapterNav && (
      <div class="mt-12 border-t border-zinc-100 pt-8">
        <ChapterNav
          nav={bundle.entryMeta.chapterNav}
          previousLabel={strings.chapterPreviousLabel}
          nextLabel={strings.chapterNextLabel}
        />
      </div>
    )}
  </div>
</Base>
