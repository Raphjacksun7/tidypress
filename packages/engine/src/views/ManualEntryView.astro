---
import Manual from '@/layouts/Manual.astro'
import SearchIndexedContent from '@/components/SearchIndexedContent.astro'
import type { RouteViewBundle } from '@/collections/bundle'

interface Props {
  bundle: RouteViewBundle
  Content: any
  mdxComponents: Record<string, any>
  headings: { depth: number; slug: string; text: string }[]
}

const { bundle, Content, mdxComponents, headings } = Astro.props
---
<Manual
  title={bundle.title}
  description={bundle.description}
  headings={headings}
  editPath={bundle.editPath}
  formLabel={bundle.entryMeta?.formLabel}
  chapterNav={bundle.entryMeta?.chapterNav}
  showChapterNavTop={bundle.entryMeta?.showChapterNavTop}
  showChapterNavBottom={bundle.entryMeta?.showChapterNavBottom}
>
  <SearchIndexedContent
    pagefindIgnore={bundle.pagefindIgnore}
    collectionKey={bundle.route.collectionKey}
  >
    <Content components={mdxComponents} />
  </SearchIndexedContent>
</Manual>
