{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist-test",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "test-support/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-test"]
}
