{
  "name": "docsmint",
  "version": "1.0.1",
  "description": "Static publishing CLI for engineer blogs and docs. Markdown in git, build once, deploy anywhere.",
  "license": "MIT",
  "type": "module",
  "author": "Raphael Avocegamou",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raphjacksun7/docsmint.git"
  },
  "homepage": "https://usedocsmint.pages.dev/",
  "bugs": {
    "url": "https://github.com/Raphjacksun7/docsmint/issues"
  },
  "bin": {
    "docsmint": "bin/docsmint.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "blog",
    "engineering-blog",
    "markdown",
    "static-site",
    "docs",
    "writing",
    "deploy"
  ],
  "exports": {
    ".": "./src/index.js",
    "./config": "./src/config.js"
  },
  "scripts": {
    "test": "node --test --test-timeout=420000",
    "dev": "node ./bin/docsmint.js dev",
    "build": "node -e \"console.log('docsmint CLI package does not require a compile step')\""
  },
  "dependencies": {
    "@docsmint/config": "workspace:*",
    "@docsmint/engine": "workspace:*",
    "jiti": "^2.6.1"
  }
}
