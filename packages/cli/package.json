{
  "name": "tidypress",
  "version": "1.0.10",
  "description": "A publishing framework for Git-native authorship.",
  "license": "MIT",
  "type": "module",
  "author": "Raphael Avocegamou",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raphjacksun7/tidypress.git"
  },
  "homepage": "https://tidypress.pages.dev/",
  "bugs": {
    "url": "https://github.com/Raphjacksun7/tidypress/issues"
  },
  "bin": {
    "tidypress": "bin/tidypress.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "blog",
    "engineering-blog",
    "markdown",
    "static-site",
    "docs",
    "writing",
    "deploy"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "skills",
    "scripts/postinstall-skills.mjs"
  ],
  "scripts": {
    "prepack": "node ./scripts/sync-skills.mjs && pnpm run build",
    "postinstall": "node ./scripts/postinstall-skills.mjs",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "dev": "tsx ./src/runCli.ts",
    "test": "pnpm run build && tsx --test --test-timeout=420000 test/*.test.ts",
    "test:install-e2e": "pnpm run build && tsx --test --test-timeout=2400000 test/install-e2e.test.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.4",
    "@astrojs/sitemap": "3.7.2",
    "@tidypress/config": "workspace:*",
    "@tidypress/engine": "workspace:*",
    "@tailwindcss/vite": "4.2.4",
    "astro": "6.2.2",
    "jiti": "2.6.1",
    "mermaid": "11.14.0",
    "pagefind": "1.5.2",
    "rehype-external-links": "3.0.0",
    "rehype-pretty-code": "0.14.3",
    "shiki": "4.0.2",
    "tailwindcss": "4.2.4",
    "unist-util-visit": "5.1.0",
    "vite": "7.3.2"
  },
  "bundleDependencies": [
    "@tidypress/config",
    "@tidypress/engine"
  ],
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
