{
  "name": "docsmint",
  "version": "1.0.7",
  "description": "Minimal markdown site for fast writing and project showcase.",
  "license": "MIT",
  "type": "module",
  "author": "Raphael Avocegamou",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raphjacksun7/docsmint.git"
  },
  "homepage": "https://usedocsmint.pages.dev/",
  "bugs": {
    "url": "https://github.com/Raphjacksun7/docsmint/issues"
  },
  "bin": {
    "docsmint": "bin/docsmint.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "blog",
    "engineering-blog",
    "markdown",
    "static-site",
    "docs",
    "writing",
    "deploy"
  ],
  "exports": {
    ".": "./src/index.js",
    "./config": "./src/config.js"
  },
  "scripts": {
    "test": "node --test --test-timeout=420000 test/*.test.js",
    "test:install-e2e": "node --test --test-timeout=2400000 test/install-e2e.test.js",
    "dev": "node ./bin/docsmint.js dev",
    "build": "node -e \"console.log('docsmint CLI package does not require a compile step')\""
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.4",
    "@astrojs/sitemap": "3.7.2",
    "@docsmint/config": "workspace:*",
    "@docsmint/engine": "workspace:*",
    "@tailwindcss/vite": "4.2.4",
    "astro": "6.2.2",
    "jiti": "2.6.1",
    "mermaid": "11.14.0",
    "pagefind": "1.5.2",
    "rehype-external-links": "3.0.0",
    "rehype-pretty-code": "0.14.3",
    "shiki": "4.0.2",
    "tailwindcss": "4.2.4",
    "unist-util-visit": "5.1.0",
    "vite": "7.3.2"
  },
  "bundleDependencies": [
    "@docsmint/config",
    "@docsmint/engine"
  ]
}
