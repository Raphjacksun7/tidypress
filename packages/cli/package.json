{
  "name": "tidypress",
  "version": "1.0.8",
  "description": "A publishing framework for Git-native authorship.",
  "license": "MIT",
  "type": "module",
  "author": "Raphael Avocegamou",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raphjacksun7/tidypress.git"
  },
  "homepage": "https://tidypress.pages.dev/",
  "bugs": {
    "url": "https://github.com/Raphjacksun7/tidypress/issues"
  },
  "bin": {
    "tidypress": "bin/tidypress.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "blog",
    "engineering-blog",
    "markdown",
    "static-site",
    "docs",
    "writing",
    "deploy"
  ],
  "exports": {
    ".": "./src/index.js",
    "./config": "./src/config.js"
  },
  "scripts": {
    "test": "node --test --test-timeout=420000 test/*.test.js",
    "test:install-e2e": "node --test --test-timeout=2400000 test/install-e2e.test.js",
    "dev": "node ./bin/tidypress.js dev",
    "build": "node -e \"console.log('tidypress CLI package does not require a compile step')\""
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.4",
    "@astrojs/sitemap": "3.7.2",
    "@tidypress/config": "workspace:*",
    "@tidypress/engine": "workspace:*",
    "@tailwindcss/vite": "4.2.4",
    "astro": "6.2.2",
    "jiti": "2.6.1",
    "mermaid": "11.14.0",
    "pagefind": "1.5.2",
    "rehype-external-links": "3.0.0",
    "rehype-pretty-code": "0.14.3",
    "shiki": "4.0.2",
    "tailwindcss": "4.2.4",
    "unist-util-visit": "5.1.0",
    "vite": "7.3.2"
  },
  "bundleDependencies": [
    "@tidypress/config",
    "@tidypress/engine"
  ]
}
