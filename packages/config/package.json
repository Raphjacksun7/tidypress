{
  "name": "@tidypress/config",
  "version": "1.0.11",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/sync-python-schemas.mjs",
    "sync-python-schemas": "node ./scripts/sync-python-schemas.mjs",
    "test": "pnpm run build && node --test test/**/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.9.2"
  },
  "private": true
}
